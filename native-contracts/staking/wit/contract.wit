package root:component;

world root {
  include kontor:built-in/built-in;
  use kontor:built-in/context.{core-context, view-context, proc-context};
  use kontor:built-in/error.{error};
  use kontor:built-in/numbers.{decimal};

  enum validator-status {
    inactive,
    active,
    pending-join,
    pending-exit,
  }

  record validator-info {
    x-only-pubkey: string,
    stake: decimal,
    status: validator-status,
    joined-epoch: u64,
    ed25519-pubkey: list<u8>,
  }

  record active-validator-info {
    x-only-pubkey: string,
    stake: decimal,
    ed25519-pubkey: list<u8>,
  }

  record epoch-info {
    epoch: u64,
    next-epoch-height: u64,
    active-count: u64,
    total-stake: decimal,
  }

  record epoch-transition-result {
    new-epoch: u64,
    activated: u64,
    deactivated: u64,
  }

  export init: async func(ctx: borrow<proc-context>);

  // --- Validator lifecycle (ProcContext — user-facing) ---
  export register-validator: async func(ctx: borrow<proc-context>, ed25519-pubkey: list<u8>, stake-amount: decimal) -> result<validator-info, error>;
  export add-stake: async func(ctx: borrow<proc-context>, amount: decimal) -> result<validator-info, error>;
  export begin-unstake: async func(ctx: borrow<proc-context>) -> result<validator-info, error>;
  export withdraw-stake: async func(ctx: borrow<proc-context>) -> result<validator-info, error>;

  // --- System initialization (CoreContext — called during native contract publishing) ---
  export set-genesis-set: async func(ctx: borrow<core-context>, validators: list<active-validator-info>);

  // --- Epoch management (CoreContext — called by block handler) ---
  export transition-epoch: async func(ctx: borrow<core-context>, block-height: u64) -> result<epoch-transition-result, error>;

  // --- Queries (ViewContext) ---
  export get-active-set: async func(ctx: borrow<view-context>) -> list<active-validator-info>;
  export get-validator: async func(ctx: borrow<view-context>, x-only-pubkey: string) -> option<validator-info>;
  export get-epoch-info: async func(ctx: borrow<view-context>) -> epoch-info;
  export get-active-count: async func(ctx: borrow<view-context>) -> u64;
}
