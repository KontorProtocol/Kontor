{
  "name": "@kontor/sdk",
  "version": "0.3.0",
  "author": "Unspendable Labs <dev@unspendablelabs.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KontorProtocol/Kontor.git",
    "directory": "sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    }
  },
  "bin": {
    "kontor-codegen": "./dist/cli.js"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "scripts": {
    "build:rs": "cd crate && ./build.sh",
    "build:ts": "vite build",
    "build": "npm run build:ts",
    "prepare": "npm run build",
    "test": "vitest",
    "test:browser": "vitest --browser"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.19.0",
    "@types/node": "^25.8.0",
    "@vitest/browser-playwright": "^4.1.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
