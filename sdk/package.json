{
  "name": "@kontor/sdk",
  "version": "0.3.0-rc.3",
  "author": "Unspendable Labs <dev@unspendablelabs.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KontorProtocol/Kontor.git",
    "directory": "sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "react-native": "./dist/index.native.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "react-native": "./dist/index.native.js",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/src/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./regtest": {
      "types": "./dist/src/regtest.d.ts",
      "import": "./dist/regtest.js"
    },
    "./wallets/sats-connect": {
      "types": "./dist/src/wallets/sats-connect.d.ts",
      "import": "./dist/wallets/sats-connect.js"
    }
  },
  "bin": {
    "kontor-codegen": "./dist/cli.js"
  },
  "peerDependencies": {
    "vite": "^8.0.0",
    "@kontor/sdk-native": "*"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@kontor/sdk-native": {
      "optional": true
    }
  },
  "scripts": {
    "build:rs": "cd ../core/kontor-sdk && ./build.sh",
    "build:ts": "vite build",
    "build:native": "KONTOR_TARGET=native vite build",
    "build": "npm run build:ts && npm run build:native",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:browser": "vitest --browser",
    "test:regtest": "npm run build && vitest --config vitest.regtest.config.ts",
    "test:regtest:browser": "npm run build && vitest --config vitest.regtest.config.ts --browser",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.19.0",
    "@types/node": "^25.8.0",
    "@vitest/browser-playwright": "^4.1.6",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@scure/btc-signer": "^2.2.0"
  }
}
