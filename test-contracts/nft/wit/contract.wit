package root:component;

world root {
  include kontor:built-in/built-in;
  use kontor:built-in/context.{holder-ref, view-context, proc-context, contract};
  use kontor:built-in/error.{error};
  use kontor:built-in/file-registry.{raw-file-descriptor};

  record nft-info {
    nft-id: string,
    owner: holder-ref,
    creator: holder-ref,
    agreement-id: string,
  }

  record nft-transfer {
    nft-id: string,
    src: holder-ref,
    dst: holder-ref,
  }

  record attribute {
    key: string,
    value: string,
  }

  export init: async func(ctx: borrow<proc-context>) -> contract;

  /// Mint a new NFT backed by a filestorage agreement created from `file-descriptor`.
  ///
  /// Validation rules enforced by the contract:
  /// - `nft-id` must be non-empty and at most 64 bytes (UTF-8 length, no
  ///   trim, case-sensitive, globally unique across all NFTs in this contract).
  /// - `attributes` describe the NFT as an immutable map of string-to-string
  ///   pairs (set once at mint, never updated afterwards). The list must
  ///   contain at most 32 entries; every `key` must be non-empty and at most
  ///   64 bytes; every `value` must be at most 2048 bytes; keys must be
  ///   unique within the list (duplicate keys cause `mint` to fail).
  /// - `file-descriptor.file-id` is freely chosen by the caller and validated
  ///   by `filestorage::create-agreement` (non-empty, etc.); it shares its
  ///   global namespace with all other agreements but is decoupled from
  ///   `nft-id`.
  ///
  /// On success the returned `agreement-id` is the agreement id created by
  /// filestorage (which equals `file-descriptor.file-id`) and is stored
  /// alongside the NFT as a link to the underlying file.
  export mint: async func(
    ctx: borrow<proc-context>,
    nft-id: string,
    attributes: list<attribute>,
    file-descriptor: raw-file-descriptor
  ) -> result<nft-info, error>;

  export transfer: async func(
    ctx: borrow<proc-context>,
    nft-id: string,
    new-owner: holder-ref
  ) -> result<nft-transfer, error>;

  export attach: async func(
    ctx: borrow<proc-context>,
    nft-id: string,
    vout: u32
  ) -> result<nft-transfer, error>;

  export detach: async func(
    ctx: borrow<proc-context>,
    nft-id: string
  ) -> result<nft-transfer, error>;

  export get-info: async func(ctx: borrow<view-context>, nft-id: string) -> option<nft-info>;
  export total-minted: async func(ctx: borrow<view-context>) -> u64;

  /// Return up to `limit` minted NFTs, skipping the first `offset` entries.
  ///
  /// Use this together with `total-minted` to paginate through the full
  /// collection. The iteration order matches the underlying storage map
  /// (lexicographic on `nft-id`) and is stable as long as the store is
  /// not mutated between calls.
  ///
  /// `limit` is silently clamped to an internal cap (currently 100) to
  /// keep response sizes predictable; pass `limit = 0` for an empty
  /// page. `offset` beyond the collection size yields an empty list.
  export list-nfts: async func(
    ctx: borrow<view-context>,
    offset: u64,
    limit: u64
  ) -> list<nft-info>;

  /// Return up to `limit` NFTs originally minted by `creator`, skipping
  /// the first `offset` matches. Backed by a secondary creator→nft-ids
  /// index that is populated at `mint` and never mutated afterwards
  /// (transfers do not move NFTs across creator buckets), so the cost
  /// is proportional to `offset + limit`.
  ///
  /// "Creator" is the signer of the `mint` call that produced the NFT;
  /// it is immutable for the lifetime of the NFT and is also exposed on
  /// `nft-info.creator`. This is the right query for "what did this
  /// account ever mint?", which is independent of who owns the NFTs
  /// today.
  ///
  /// The same clamping rules as `list-nfts` apply (`limit` is capped at
  /// an internal maximum, `limit = 0` returns an empty list, and an
  /// `offset` beyond the creator's collection yields an empty list). The
  /// iteration order matches the underlying storage map (lexicographic
  /// on `nft-id`) and is stable between calls as long as the store is
  /// not mutated. An invalid or never-seen `creator` yields an empty
  /// list rather than an error.
  export list-nfts-by-creator: async func(
    ctx: borrow<view-context>,
    creator: holder-ref,
    offset: u64,
    limit: u64
  ) -> list<nft-info>;

  /// Number of NFTs minted by `creator`. Equivalent to the length of
  /// the full (non-paginated) `list-nfts-by-creator` result. Returns 0
  /// when `creator` has no entry in the index.
  export count-nfts-by-creator: async func(
    ctx: borrow<view-context>,
    creator: holder-ref
  ) -> u64;

  /// Return up to `limit` NFTs currently held by `holder`, skipping the first
  /// `offset` matches. Backed by an append-only holder→nft-ids index populated
  /// on every ownership change (`mint`, `transfer`, `attach`, `detach`); ids a
  /// holder has since transferred away linger in the index and are filtered out
  /// here by re-checking current ownership, so the result always reflects who
  /// owns the NFTs today.
  ///
  /// The same clamping rules as `list-nfts` apply. An invalid or never-seen
  /// `holder` yields an empty list rather than an error.
  export list-nfts-by-holder: async func(
    ctx: borrow<view-context>,
    holder: holder-ref,
    offset: u64,
    limit: u64
  ) -> list<nft-info>;

  /// Number of NFTs currently held by `holder`. O(1). Returns 0 for unknown holders.
  export count-nfts-by-holder: async func(
    ctx: borrow<view-context>,
    holder: holder-ref
  ) -> u64;

  export get-attributes: async func(ctx: borrow<view-context>, nft-id: string) -> list<attribute>;
  export get-attribute: async func(ctx: borrow<view-context>, nft-id: string, key: string) -> option<string>;
}
