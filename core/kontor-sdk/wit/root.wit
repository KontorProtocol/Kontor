package root:component;

/// Wit document resource. Held by the consumer for the lifetime of one
/// WIT (typically: one Kontor contract). Resources can only be exported
/// via an interface, not directly from a world.
interface wit-codec {
  /// One instance per WIT document. Holds the parsed Resolve graph
  /// internally; methods take a function name + JSON-encoded args (or
  /// WAVE string) and return WAVE / JSON respectively.
  resource wit {
    constructor(text: string);
    encode-call: func(fn-name: string, args-json: string) -> result<string, string>;
    decode-result: func(fn-name: string, wave: string) -> result<string, string>;
    parse: func() -> result<string, string>;
  }
}

/// Mirror of Kontor's built-in `numbers` interface — exposes the same
/// arithmetic operations on Integer/Decimal that contracts get from the
/// chain. Backed by the shared `core/numerics` crate so SDK arithmetic
/// is byte-for-byte identical to chain arithmetic.
interface numerics {
  enum sign { plus, minus }
  enum ordering { less, equal, greater }
  record integer { r0: u64, r1: u64, r2: u64, r3: u64, sign: sign }
  record decimal { r0: u64, r1: u64, r2: u64, r3: u64, sign: sign }
  variant numerics-error {
    message(string),
    overflow(string),
    div-by-zero(string),
    syntax(string),
    validation(string),
  }

  u64-to-integer: func(i: u64) -> integer;
  s64-to-integer: func(i: s64) -> integer;
  string-to-integer: func(s: string) -> result<integer, numerics-error>;
  integer-to-string: func(i: integer) -> string;
  eq-integer: func(a: integer, b: integer) -> bool;
  cmp-integer: func(a: integer, b: integer) -> ordering;
  add-integer: func(a: integer, b: integer) -> result<integer, numerics-error>;
  sub-integer: func(a: integer, b: integer) -> result<integer, numerics-error>;
  mul-integer: func(a: integer, b: integer) -> result<integer, numerics-error>;
  div-integer: func(a: integer, b: integer) -> result<integer, numerics-error>;
  sqrt-integer: func(i: integer) -> result<integer, numerics-error>;

  integer-to-decimal: func(i: integer) -> result<decimal, numerics-error>;
  decimal-to-integer: func(d: decimal) -> result<integer, numerics-error>;
  u64-to-decimal: func(i: u64) -> result<decimal, numerics-error>;
  s64-to-decimal: func(i: s64) -> result<decimal, numerics-error>;
  f64-to-decimal: func(f: f64) -> result<decimal, numerics-error>;
  string-to-decimal: func(s: string) -> result<decimal, numerics-error>;
  decimal-to-string: func(d: decimal) -> string;
  eq-decimal: func(a: decimal, b: decimal) -> result<bool, numerics-error>;
  cmp-decimal: func(a: decimal, b: decimal) -> ordering;
  add-decimal: func(a: decimal, b: decimal) -> result<decimal, numerics-error>;
  sub-decimal: func(a: decimal, b: decimal) -> result<decimal, numerics-error>;
  mul-decimal: func(a: decimal, b: decimal) -> result<decimal, numerics-error>;
  div-decimal: func(a: decimal, b: decimal) -> result<decimal, numerics-error>;
  log10-decimal: func(a: decimal) -> result<decimal, numerics-error>;
}

world root {
  // The codec functions validate their input — bad JSON, a malformed
  // x-only pubkey, a corrupt byte buffer — and surface it as the `err`
  // arm rather than trapping. `result` so the host gets a catchable
  // error string, not an `unreachable`.
  export serialize-inst: func(json-str: string) -> result<list<u8>, string>;
  export deserialize-inst: func(bytes: list<u8>) -> result<string, string>;

  // BLS12-381 key material + signing. Bytes are guaranteed identical
  // to the indexer-side verification path because both link the same
  // `bls-crypto` crate (and therefore the same `blst`).
  //
  // - `bls-secret-key-gen`: HKDF-based KeyGen from draft-irtf-cfrg-
  //   bls-signature-05. Caller supplies ≥32 bytes of input keying
  //   material (the TS side reads it from webcrypto); blst always
  //   produces a valid scalar < curve order. Entropy generation
  //   stays in the host so the wasm doesn't have to depend on
  //   `getrandom`'s `js` feature.
  // - `bls-secret-from-seed-eip2333`: deterministic derivation along
  //   `path` (EIP-2334-style indices). The TS side builds the path
  //   from its `Chain` — the Kontor convention is
  //   `[12381, coin_type, 0, 0]` (0 mainnet, 1 elsewhere).
  // - `bls-pubkey-from-secret`: 96-byte compressed G2 pubkey (min_sig).
  // - `bls-sign`: 48-byte compressed G1 signature under KONTOR_BLS_DST.
  //   Hash-to-curve happens inside blst — pass the raw message bytes.
  export bls-secret-key-gen: func(ikm: list<u8>) -> result<list<u8>, string>;
  export bls-secret-from-seed-eip2333: func(seed: list<u8>, path: list<u32>) -> result<list<u8>, string>;
  export bls-pubkey-from-secret: func(secret: list<u8>) -> result<list<u8>, string>;
  export bls-sign: func(secret: list<u8>, message: list<u8>) -> result<list<u8>, string>;
  // BLS single-signature verify under KONTOR_BLS_DST. Returns Ok(true)
  // on valid, Ok(false) on a well-formed but non-verifying signature,
  // Err for malformed pubkey / signature bytes. Subgroup-validates
  // both. Used by the aggregator side to gate fragments before combining.
  export bls-verify: func(pubkey: list<u8>, message: list<u8>, signature: list<u8>) -> result<bool, string>;

  // Aggregate-call building blocks. The bytes flowing through these are
  // exactly what the indexer's `bls/aggregate.rs` verifier consumes —
  // implemented against the same `indexer-types` / `bls-crypto` source
  // so contributor signatures verify on chain.
  //
  // - `aggregate-signing-message`: per-op message a contributor BLS-
  //   signs. Mirrors `Inst::aggregate_signing_message` —
  //   `"KONTOR-OP-V1" ++ postcard((SignerRef, nonce, sponsored, Inst))`.
  //   Takes the `claim` and `inst` as JSON (round-trips through the
  //   same `indexer_types` types so bytes are guaranteed identical to
  //   what the indexer would produce).
  // - `bls-aggregate-signatures`: combine per-op signatures into one
  //   48-byte aggregate signature (blst's `AggregateSignature`). The
  //   aggregator embeds the result in `AggregateInfo.signature`.
  export aggregate-signing-message: func(claim-json: string, nonce: u64, sponsored: bool, inst-json: string) -> result<list<u8>, string>;
  export bls-aggregate-signatures: func(signatures: list<list<u8>>) -> result<list<u8>, string>;

  // A transaction's OP_RETURN payload: one `op-return-entry` per reveal
  // input that detaches an asset, binding that input to the recipient
  // the asset lands with. `signer-ref` names a party by existing signer
  // id or by x-only pubkey. `encode`/`decode` own the wire (postcard)
  // shape — these types mirror the Rust 1:1.
  variant signer-ref {
    signer-id(u64),
    x-only-pubkey(string),
  }

  record op-return-entry {
    input-index: u32,
    recipient: signer-ref,
  }

  export encode-op-return: func(entries: list<op-return-entry>) -> result<list<u8>, string>;
  export decode-op-return: func(bytes: list<u8>) -> result<list<op-return-entry>, string>;

  record validation-error {
    message: string,
    location: string,
  }

  variant validation-result {
    ok,
    parse-error(string),
    validation-errors(list<validation-error>),
  }

  export validate-wit: func(wit-content: string) -> validation-result;

  export wit-codec;
  export numerics;
}
